{
  "name": "interactive-graphviz-server",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run server.ts",
    "test": "bun test",
    "build": "bun build server.ts --target=bun --outdir ../dist/server",
    "release:targets": "bun run ../scripts/release.ts validate-targets",
    "release:build": "bun run ../scripts/release.ts build --out-dir ../dist/release --write-checksums ../checksums.txt"
  },
  "devDependencies": {
    "@hpcc-js/wasm-graphviz": "1.21.2"
  }
}
